@article{trainaA3COSMOSDustMass2024,
  title = {{{A3COSMOS}}: {{Dust}} Mass Function and Dust Mass Density at 0.5 {$<$} z {$<$} 6},
  shorttitle = {{{A3COSMOS}}},
  author = {Traina, A. and Magnelli, B. and Gruppioni, C. and Delvecchio, I. and Parente, M. and Calura, F. and Bisigello, L. and Feltre, A. and Pozzi, F. and Vallini, L.},
  year = 2024,
  month = oct,
  journal = {Astronomy and Astrophysics},
  volume = {690},
  pages = {A84},
  publisher = {EDP},
  issn = {0004-6361},
  doi = {10.1051/0004-6361/202451113},
  urldate = {2026-03-25},
  abstract = {Context. Although dust in galaxies represents only a few percent of the total baryonic mass, it plays a crucial role in the physical processes occurring in galaxies. Studying the dust content of galaxies, particularly at high z, is therefore crucial for understanding the link between dust production, obscured star formation, and the build-up of galaxy stellar mass. Aims. We study the dust properties (mass and temperature) of the largest Atacama Large Millimeter/submillimeter Array (ALMA)-selected sample of star-forming galaxies available from the archive (A3COSMOS), and we derive the dust mass function and dust mass density of galaxies from z = 0.5 - 6. Methods. We fit the spectral energy distribution (SED) with the CIGALE code to constrain the dust mass and temperature of the A3COSMOS galaxy sample based on the UV-to-near-infrared photometric coverage of each galaxy combined with the ALMA (and Herschel when available) coverage of the Rayleigh-Jeans tail of their dust-continuum emission. We then computed and fit the dust mass function by combining the A3COSMOS and the most recent Herschel samples in order to obtain the best estimate of the integrated dust mass density up to z {$\sim$} 6. Results. The dust masses in galaxies in A3COSMOS lie between {$\sim$}108 and {$\sim$}109.5 M{$\odot$}. From the SED fitting, we were also able to derive a dust temperature. The distribution of the dust temperature peaks at {$\sim$}30 - 35 K. The dust mass function at z = 0.5 - 6 evolves with an increase in M* and a decrease in the number density ({$\Phi$}*), and it agrees well with literature estimates. The dust mass density decreases smoothly in its evolution from z {$\sim$} 0.5 to z {$\sim$} 6, which is steeper than what is found by models at z {$\greaterequivlnt$} 2.},
  keywords = {Astrophysics - Astrophysics of Galaxies,farIR,galaxies: evolution,galaxies: high-redshift,galaxies: luminosity function,galaxies: star formation,mass function,submillimeter: galaxies,surveys},
  annotation = {ADS Bibcode: 2024A\&A...690A..84T},
  file = {/home/sid/Zotero/storage/WMCZRT7W/Traina et al. - 2024 - A3COSMOS Dust mass function and dust mass density at 0.5  z  6.pdf}
}

