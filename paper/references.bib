  doi = {10.1111/j.1365-2966.2009.15197.x},
  urldate = {2026-03-18},
  abstract = {We present number counts, luminosity functions (LFs) and luminosity densities of galaxies obtained using the Sloan Digital Sky Survey Sixth Data Release (SDSS DR6) in all SDSS photometric bands. Thanks to the SDSS DR6, galaxy statistics have increased by a factor of {$\sim$}7 in the u band and by a factor between {$\sim$}3 and {$\sim$}5 in the rest of the SDSS bands with respect to the previous work of Blanton et al. In addition, we have ensured a high redshift completeness in our galaxy samples, mainly by minimizing the effect of brightness-dependent incompleteness. With these advances, we have estimated very accurate SDSS DR6 LFs at both the bright and the faint end. In the 0.1r band, our LF is well fitted by a Schechter LF with parameters {$\Phi$}*= 0.93 \textpm{} 0.07, M*- 5log10h=-20.71 \textpm{} 0.04 and {$\alpha$}=-1.26 \textpm{} 0.02. As compared with previous results, we find some notable differences. At the bright end of the 0.1u-band LF we find a remarkable excess, of {$\sim$}1.7 dex at , with respect to the best-fitting Schechter LF. This excess weakens in the 0.1g band, fading away towards the very red 0.1z band. A preliminary analysis on the nature of this bright-end bump reveals that it is composed of quasi-stellar objects/type 1 Seyferts ({$\sim$}60 per cent), starbursts and star-forming galaxies ({$\sim$}20 per cent) and normal galaxies ({$\sim$}20 per cent). It seems, therefore, that an important fraction of this excess luminosity may come from nuclear activity. At the faint end of the SDSS DR6 LFs, where we can reach 0.5--1 mag deeper than the previous SDSS LF estimations, we obtain a steeper slope that increases from the 0.1u band, with {$\alpha$}=-1.05 \textpm{} 0.05, to the very red 0.1z band, with {$\alpha$}=-1.26 \textpm{} 0.03. We have also investigated the effect of galaxy evolution on our LFs. These state-of-the-art results may be used to constrain a variety of aspects of star formation histories and/or feedback processes in galaxy formation models.},
  file = {/home/sid/Zotero/storage/AC6KM8WX/Montero-Dorta and Prada - 2009 - The SDSS DR6 luminosity functions of galaxies.pdf;/home/sid/Zotero/storage/DI982K7I/j.1365-2966.2009.15197.html}
}

@article{murphyExcessHighfrequencyRadio2018,
  title = {Excess in the {{High-frequency Radio Background}}: {{Insights}} from {{Planck}}},
  shorttitle = {Excess in the {{High-frequency Radio Background}}},
  author = {Murphy, Eric J. and Chary, Ranga-Ram},
  year = 2018,
  month = jun,
  journal = {The Astrophysical Journal},
  volume = {861},
  number = {1},
  pages = {27},
  publisher = {The American Astronomical Society},
  issn = {0004-637X},
  doi = {10.3847/1538-4357/aac2b6},
  urldate = {2026-03-23},
  abstract = {We conduct a stacking analysis using the combination of 1.4 GHz detections in the NRAO VLA Sky Survey (NVSS) and Planck all-sky maps to estimate the differential source counts down to the few 100 {$\mu$}Jy level at 30, 44, 70, and 100 GHz. Using these source count estimates, we are able to measure the integrated extragalactic background light from discrete sources at these frequencies for comparison with the fit to the total radio sky measurements from ARCADE 2. By integrating down to a 1.4 GHz flux density of {$\approx$}2 {$\mu$}Jy, we measure integrated, extragalactic brightness temperatures from discrete sources of 105.63 \textpm{} 10.56 mK, 21.76 \textpm{} 3.09 {$\mu$}K, 8.80 \textpm{} 0.95 {$\mu$}K, 2.59 \textpm{} 0.27 {$\mu$}K, and 1.15 \textpm{} 0.10 {$\mu$}k at 1.4, 30, 44, 70, and 100 GHz, respectively. Our measurement at 1.4 GHz is slightly larger than previous measurements, most likely due to using NVSS data compared with older interferometric data in the literature, but it still remains a factor of {$\approx$}4.5 below that required to account for the excess extragalactic sky brightness measured at 1.4 GHz by ARCADE 2. The fit to ARCADE 2 total extragalactic sky brightness measurements is also a factor of {$\approx$}8.6, 6.6, 6.2, and 4.9 times brighter than what we estimate from discrete sources at 30, 44, 70, and 100 GHz, respectively. The extragalactic sky spectrum (i.e., Tb {$\propto$} {$\nu\beta$}) from discrete sources appears to flatten with increasing frequency, having a spectral index of {$\beta$} = -2.82 \textpm{} 0.06 between 1.4 and 30 GHz, flattening to {$\beta$} = -2.39 \textpm{} 0.12 between 30 and 100 GHz. We estimate that the spectral flattening most likely arises from a combination of gigahertz-peaked sources and the hardening of the spectra of radio-detected sources at higher frequencies, particularly at faint flux densities. However, the precise origin of a hard component of energetic electrons responsible for the emission remains unclear.},
  langid = {english},
  file = {/home/sid/Zotero/storage/VMK7L6BV/Murphy and Chary - 2018 - Excess in the High-frequency Radio Background Insights from Planck.pdf}
}

