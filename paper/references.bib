  title = {Cosmological Simulations of Galaxy Formation},
  author = {Vogelsberger, Mark and Marinacci, Federico and Torrey, Paul and Puchwein, Ewald},
  year = 2020,
  month = jan,
  journal = {Nature Reviews Physics},
  volume = {2},
