@article{bietenholzRadioLuminosityrisetimeFunction2021,
  title = {The {{Radio Luminosity-risetime Function}} of {{Core-collapse Supernovae}}},
  author = {Bietenholz, M. F. and Bartel, N. and Argo, M. and Dua, R. and Ryder, S. and Soderberg, A.},
  year = 2021,
  month = feb,
  journal = {The Astrophysical Journal},
  volume = {908},
  number = {1},
  pages = {75},
  publisher = {The American Astronomical Society},
  issn = {0004-637X},
  doi = {10.3847/1538-4357/abccd9},
  urldate = {2026-03-16},
  abstract = {We assemble a large set of 2--10 GHz radio flux density measurements and upper limits of 294 different supernovae (SNe), from the literature and our own and archival data. Only 31\% of SNe were detected. We characterize the SN radio lightcurves near the peak using a two-parameter model, with t pk being the time to rise to a peak and L pk the spectral luminosity at that peak. Over all SNe in our sample at D {$<$} 100 Mpc, we find that t pk = 101.7\textpm 0.9 days and that L pk = 1025.5\textpm 1.6 erg s-1 Hz-1, and therefore that generally 50\% of SNe will have L pk {$<$} 1025.5 erg s-1 Hz-1. These L pk values are {$\sim$}30 times lower than those for only detected SNe. Types Ib/c and II (excluding IIn's) have similar mean values of L pk but the former have a wider range, whereas Type IIn SNe have {$\sim$}10 times higher values with L pk = 1026.5\textpm 1.1 erg s-1 Hz-1. As for t pk, Type Ib/c have t pk of only 101.1\textpm 0.5 days while Type II have t pk = 101.6\textpm 1.0 and Type IIn the longest timescales with t pk = 103.1\textpm 0.7 days. We also estimate the distribution of progenitor mass-loss rates, , and find that the mean and standard deviation of are -5.4 \textpm{} 1.2 (assuming v wind = 1000 km s-1) for Type Ib/c SNe, and -6.9 \textpm{} 1.4 (assuming v wind = 10 km s-1) for Type II SNe excluding Type IIn.},
  langid = {english},
  keywords = {radio},
  file = {/home/sid/Zotero/storage/86N2XCAJ/Bietenholz et al. - 2021 - The Radio Luminosity-risetime Function of Core-collapse Supernovae.pdf}
}

