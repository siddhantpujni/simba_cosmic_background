  author = {Liang, Lichen and Feldmann, Robert and Kere{\v s}, Du{\v s}an and Scoville, Nick Z and Hayward, Christopher C and {Faucher-Gigu{\`e}re}, Claude-Andr{\'e} and Schreiber, Corentin and Ma, Xiangcheng and Hopkins, Philip F and Quataert, Eliot},
  year = 2019,
